# Copy to ".env" and adjust for your environment. Used by docker-compose.yml.
# Do NOT commit the real .env (it is gitignored).

# SQL Server 'sa' password. Must satisfy SQL Server complexity rules
# (>= 8 chars incl. upper, lower, digit, symbol).
SA_PASSWORD=TaskManager2026!

# JWT signing key. Must be at least 32 characters. Use a long random value in production.
JWT_KEY=docker-compose-super-secret-jwt-signing-key-change-me-please
